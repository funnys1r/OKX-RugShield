{
  "name": "okx-rugshield",
  "version": "1.0.0",
  "description": "OKX RugShield - A dual-skill onchain risk defense agent for threat detection, wallet exposure checks, and staged defensive responses",
  "main": "cli/rugshield.js",
  "bin": {
    "rugshield": "./cli/rugshield.js"
  },
  "scripts": {
    "start": "node cli/rugshield.js",
    "preflight": "bash scripts/preflight.sh",
    "preflight:verbose": "bash -x scripts/preflight.sh",
    "demo": "node cli/rugshield.js --mock",
    "replay:mock": "node cli/replay-mock.js",
    "patrol:mock": "node cli/patrol-mock.js",
    "simulate:guardian": "node cli/simulate-guardian.js",
    "live:signal": "node cli/fetch-live-signal.js",
    "live:portfolio": "node cli/live-portfolio-guardian.js",
    "benchmark": "node scripts/benchmark-runner.js --scenarios=./scenarios/demo-scenarios.v1.json",
    "benchmark:strict": "node scripts/benchmark-runner.js --scenarios=./scenarios/demo-scenarios.v1.json --strict",
    "benchmark:verbose": "node scripts/benchmark-runner.js --scenarios=./scenarios/demo-scenarios.v1.json --verbose",
    "test": "npm run preflight && npm run demo && npm run replay:mock && npm run patrol:mock && npm run simulate:guardian",
    "install:core": "node scripts/installer.js --core-only",
    "install:dry": "node scripts/installer.js --core-only --dry-run"
  },
  "keywords": [
    "okx",
    "onchainos",
    "openclaw",
    "rugshield",
    "defense-agent",
    "risk-management",
    "wallet-security",
    "defi"
  ],
  "author": "CTO-CT-SF",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
